# Database
# Full PostgreSQL connection string — from Neon (dev) or AWS Secrets Manager (production)
# Note: src/db/index.ts currently reads DATABASE_URL — rename to POSTGRES_URL as part of Phase 3.1
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Authentication & security
# Random string of at least 32 characters — used to authenticate /api/cron/weekly-start requests
CRON_SECRET=your-cron-secret-here

# Random string of at least 32 characters — used to authenticate admin endpoints
DEMO_ADMIN_KEY=your-demo-admin-key-here

# Random string of at least 32 characters — salts SHA-256 hashes of SA ID numbers
# WARNING: changing this after users have registered will invalidate all stored hashes
SA_ID_HASH_SALT=your-sa-id-hash-salt-here

# HMAC secret for verifying inbound WhatsApp webhook signatures (Phase 6)
# Value comes from the S2S WhatsApp provider dashboard
WHATSAPP_WEBHOOK_SECRET=your-whatsapp-webhook-secret-here

# AWS — SQS integration (Phase 5)
# Region where your SQS queue lives
AWS_REGION=af-south-1

# Full SQS queue URL — available from the AWS SQS console after the queue is created
# Example: https://sqs.af-south-1.amazonaws.com/123456789012/spaza-whatsapp-inbound
SQS_INBOUND_QUEUE_URL=https://sqs.af-south-1.amazonaws.com/YOUR_ACCOUNT_ID/spaza-whatsapp-inbound

# Public site URL — used when building registration and prediction links sent to users
# Set to https://winakasiwina.co.za in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — override the current ISO week for testing without waiting for a real week boundary
# Format: YYYY-Www  e.g. 2026-W18
# CURRENT_WEEK_ID=2026-W18
