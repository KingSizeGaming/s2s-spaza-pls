{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "typeRoots": ["../whatsapp-processor/node_modules/@types"],
    "types": ["node", "aws-lambda"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "drizzle-orm": ["../whatsapp-processor/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../whatsapp-processor/node_modules/drizzle-orm/*"],
      "@aws-sdk/*": ["../whatsapp-processor/node_modules/@aws-sdk/*"]
    }
  },
  "include": ["**/*.ts"]
}
