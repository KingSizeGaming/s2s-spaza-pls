{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "types": ["node", "aws-lambda"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "drizzle-orm": ["node_modules/drizzle-orm"],
      "drizzle-orm/*": ["node_modules/drizzle-orm/*"],
      "pg": ["node_modules/pg"],
      "@aws-sdk/*": ["node_modules/@aws-sdk/*"]
    }
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
